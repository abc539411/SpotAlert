# Claude Code internal files
.claude/

# Runtime secrets
data/.fr24_cookies.pkl
data/.secret_key

# Deploy script passwords — copy deploy.local.ps1.example to fill in
deploy.local.ps1

# Runtime downloaded assets — fetched on demand, not committed
static/airline_logos/
static/translations/

# Runtime database in data/ — static JSON files in data/ are tracked
data/*.db
data/*.db-shm
data/*.db-wal
data/backups/

# Local pre-migration backups (DB dumps pulled from the deployed server)
/backups/

# Logs
logs/

# Personal planning notes and docs
to_do.md
docs/

# Lightroom catalog (personal data, large binary)
lightroom/*.lrcat
lightroom/*.lrcat-journal
lightroom/*.lrcat-shm
lightroom/*.lrcat-wal

# Catalog working folder (drop .lrcat here, get cleaned .lrcat out)
catalog/*.lrcat
catalog/*.lrcat-journal
catalog/*.lrcat-shm
catalog/*.lrcat-wal
catalog/fr24_cache.json
catalog/airline_codes.json
catalog/user_overrides.json

# Scripts catalog folder — same rules
scripts/catalog/*.lrcat
scripts/catalog/*.lrcat-journal
scripts/catalog/*.lrcat-shm
scripts/catalog/*.lrcat-wal
scripts/catalog/fr24_cache.json
scripts/catalog/airline_codes.json
scripts/catalog/user_overrides.json

# SpotAlert Studio — local runtime data (thumbnails cache, inbox/output test photos, its own log)
studio/data/thumbnails/
studio/data/inbox/
studio/data/output/
studio/server.log

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
