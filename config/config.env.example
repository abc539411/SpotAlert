### TELEGRAM
TELEGRAM_BOT_TOKEN = your_bot_token_here
CHAT_ID = your_chat_id_here

# How often to poll FR24 for new arrivals, in minutes
CHECK_INTERVAL_MINUTES = 30

### FLIGHTRADAR24
AIRPORT_CODE = SYD

# How many arriving flights to fetch per check (FR24 returns 100 per page)
ARRIVALS_TO_FETCH = 200

### SPECIAL LIVERY FILTER
# Hours before the same registration can re-trigger this filter
SPECIAL_LIVERY_RENOTIFY_HOURS = 12
# Keywords matched against the airline name field in FR24 (comma-separated)
SPECIAL_LIVERY_KEYWORDS = Livery,livery,Sticker,sticker
# Days of the week to send notifications — leave empty for all days (e.g. Sat,Sun)
SPECIAL_LIVERY_ACTIVE_DAYS =
# Arrival window filter — empty = always notify, Daylight = daylight arrivals only, Off = disabled
SPECIAL_LIVERY_ARRIVAL_WINDOW =

### RARE PLANE FILTER
# A combo is considered "rare" only if it hasn't been seen for this many days.
# Every sighting refreshes the clock — so a daily arrival will never trigger this filter.
RARE_PLANE_MIN_ABSENCE_DAYS = 7
# Days of the week to send notifications — leave empty for all days
RARE_PLANE_ACTIVE_DAYS =
# Arrival window filter — empty = always notify, Daylight = daylight arrivals only, Off = disabled
RARE_PLANE_ARRIVAL_WINDOW =

### REGO WATCHLIST FILTER
# Hours before the same registration can re-trigger this filter
REGO_WATCHLIST_RENOTIFY_HOURS = 12
# Days of the week to send notifications — leave empty for all days
REGO_WATCHLIST_ACTIVE_DAYS =
# Arrival window filter — empty = always notify, Daylight = daylight arrivals only, Off = disabled
REGO_WATCHLIST_ARRIVAL_WINDOW =

### TYPE WATCHLIST FILTER
# Hours before the same airline + aircraft type combo can re-trigger this filter
TYPE_WATCHLIST_RENOTIFY_HOURS = 12
# Days of the week to send notifications — leave empty for all days
TYPE_WATCHLIST_ACTIVE_DAYS =
# Arrival window filter — empty = always notify, Daylight = daylight arrivals only, Off = disabled
TYPE_WATCHLIST_ARRIVAL_WINDOW =

### SUMMARY COMMAND
# Morning period: starts X hours before sunrise, ends at Y:00 local time
SUMMARY_MORNING_PRE_SUNRISE_HOURS = 1
SUMMARY_MORNING_END_HOUR = 12
# Afternoon period: starts at Z:00 local time, ends M hours after sunset
SUMMARY_AFTERNOON_START_HOUR = 12
SUMMARY_AFTERNOON_POST_SUNSET_HOURS = 1

### MILITARY AIRCRAFT FILTER (adsb.fi open data — no API key required)
# How often to check for military aircraft, in minutes
MILITARY_CHECK_INTERVAL_MINUTES = 15
# Search radius around the airport in nautical miles (max 250)
MILITARY_RADIUS_NM = 50
# Maximum altitude in feet to consider a military aircraft "on approach"
MILITARY_MAX_ALT_FT = 5000
# Hours before the same registration can re-trigger this filter
MILITARY_RENOTIFY_HOURS = 4
